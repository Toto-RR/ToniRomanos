---
import Layout from "../../layouts/Layout.astro";
import GitHub from "../../components/icons/GitHub.astro";
import Link from "../../components/icons/Link.astro";
import LinkButton from "../../components//LinkButton.astro";
import Youtube from "../../components/icons/Youtube.astro";

import { PROJECTS } from "@/data/projects";

export function getStaticPaths() {
  return PROJECTS.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<style>
  :global(.detailText p + p) {
    margin-top: 5rem; /* espacio entre párrafos */
  }

  :global(.detailText p) {
    line-height: 1.6; /* altura de línea normal */
    margin-bottom: 0; /* opcional, para que el espacio lo controle la regla de arriba */
  }

  h1 {
    padding-top: 32px;
    font-size: 4rem;
    font-weight: 700;
    color: rgb(254, 240, 138);
    text-align: center;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: rgb(138, 254, 219);
  }

  .prose p {
    margin-bottom: 2rem;
  }

  p {
    color: currentColor;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5rem;
    }
  }

  :global(strong) {
    color: #38bdf8;
  }
</style>

<Layout
  title={project.title}
  description={`Detalles del proyecto ${project.title}. ${project.description.replace(/<[^>]+>/g, "").slice(0, 150)}...`}
  headerVariant="minimal"
>
  <main class="max-w-7xl mx-auto px-6 md:px-16 lg:px-32 py-12 space-y-8">
    <h1>
      {project.title}
    </h1>

    <div
      class=""
    >
      <!-- VIDEO / IMAGEN -->
      <div class="w-full">
        {
          project.youtubeVideoId && (
            <div class="w-full aspect-video">
              <iframe
                class="w-full h-full rounded-xl"
                src={`https://www.youtube.com/embed/${project.youtubeVideoId}`}
                title={`Trailer ${project.title}`}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            </div>
          )
        }

        {
          !project.youtubeVideoId && project.trailer && (
            <div class="w-full aspect-video">
              <video
                class="w-full h-full rounded-xl block object-cover"
                controls
                playsinline
                preload="metadata"
                poster={project.image}
              >
                <source src={project.trailer} type="video/mp4" />
              </video>
            </div>
          )
        }

        {
          !project.youtubeVideoId && !project.trailer && (
            <img
              src={project.image}
              alt={`Imagen del proyecto ${project.title}`}
              class="w-full h-auto rounded-xl object-cover"
            />
          )
        }
      </div>
    </div>
    <!-- TEXTO -->
      <div class="w-full flex flex-col justify-start gap-12">
        <div class="space-y-6">
          {
            (project.detail?.explication ?? []).map((paragraph: string) => (
              <div class="leading-relaxed text-lg" set:html={paragraph} />
            ))
          }
        </div>
        <div class="space-y-6">
          {
            project.detail?.myRole && (
              <div class="detailText mx-auto">
                <h2>Mi rol en el proyecto</h2>
                <div
                  class="leading-relaxed text-lg mt-4 space-y-4"
                  set:html={project.detail.myRole}
                />
              </div>
            )
          }
        </div>
      </div>
    {
      project.gallery && (
        <section class="mt-24 space-y-16 pt-16">
          <h2 class="text-3xl font-bold text-center text-yellow-200">
            Galería
          </h2>

          <div class="columns-1 md:columns-2 xl:columns-2 gap-8 space-y-8">
            {project.gallery.map((item) => (
              <div class="mb-8 break-inside-avoid space-y-3">
                {item.title && (
                  <h3 class="text-xl font-semibold text-cyan-200">
                    {item.title}
                  </h3>
                )}

                {item.description && (
                  <p class="text-gray-400">{item.description}</p>
                )}

                {item.type === "image" && (
                  <img
                    src={item.src}
                    alt={item.title ?? "Project media"}
                    class="w-full rounded-xl"
                  />
                )}

                {item.type === "video" && (
                  <video class="w-full rounded-xl" controls preload="metadata">
                    <source src={item.src} type="video/mp4" />
                  </video>
                )}

                {item.type === "youtube" && (
                  <div class="aspect-video">
                    <iframe
                      class="w-full h-full rounded-xl"
                      src={`https://www.youtube-nocookie.com/embed/${item.src}`}
                      title={item.title ?? "YouTube video"}
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    />
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )
    }
  </main>
</Layout>
