---
/**
 * PLANTILLA DE PÁGINA DE PROYECTO
 * 
 * Uso: duplica este archivo en src/pages/projects/[tu-proyecto].astro
 * y rellena el objeto `project` con los datos de tu proyecto.
 * 
 * Para personalizar el color de acento de cada proyecto,
 * cambia las variables --project-accent y --project-accent-soft.
 */

// ─── DATOS DEL PROYECTO ───────────────────────────────────────────────────────
const project = {
  // Identidad
  title: "Nombre del Proyecto",
  subtitle: "Categoría · Tipo",
  tagline: "Una frase corta que resume de qué va el proyecto y qué lo hace especial.",
  year: "2024",
  duration: "4 meses",
  role: "Gameplay Programmer",
  team: "Solo / Equipo de X",
  status: "Completado", // "En desarrollo" | "Completado" | "Prototipo"

  // Color de acento propio del proyecto (cambia esto por proyecto)
  // Ejemplos: azul "#3b82f6" | verde "#22c55e" | naranja "#f97316" | cyan "#06b6d4"
  accent: "#f51a29",        // color principal
  accentSoft: "rgba(245, 26, 41, 0.14)", // versión translúcida

  // Hero
  cover: "/media/projects/tu-proyecto/cover.webp", // imagen de portada
  coverVideo: "/media/projects/tu-proyecto/gameplay.mp4", // opcional, null si no hay

  // Tech stack usado
  tags: ["Unity", "C#", "Gameplay", "Physics"],

  // Descripción larga (puede incluir HTML básico con <strong>)
  description: `
    Descripción completa del proyecto. Habla de qué es, para quién es y qué problema resuelve o experiencia crea.
    Puedes usar <strong>negrita</strong> para destacar conceptos clave.
    Intenta ser concreto: qué tipo de juego, qué mecánicas principales, cuál era el objetivo.
  `,

  // Galería: mezcla de imágenes y vídeos
  gallery: [
    { type: "image", src: "/media/projects/tu-proyecto/screenshot-1.webp", caption: "Descripción opcional" },
    { type: "image", src: "/media/projects/tu-proyecto/screenshot-2.webp", caption: "" },
    { type: "video", src: "/media/projects/tu-proyecto/clip-1.mp4",        caption: "Gameplay en acción" },
    { type: "image", src: "/media/projects/tu-proyecto/screenshot-3.webp", caption: "" },
  ],

  // Arquitectura / sistemas técnicos
  systems: [
    {
      title: "Sistema de nombre",
      description: "Explica cómo funciona este sistema, por qué lo diseñaste así y qué problema resuelve dentro del juego.",
      tags: ["C#", "Unity Events"],
    },
    {
      title: "Otro sistema",
      description: "Descripción del sistema. Sé específico: patrones usados, decisiones de arquitectura, trade-offs.",
      tags: ["ScriptableObjects", "State Machine"],
    },
    {
      title: "Tercer sistema",
      description: "Descripción.",
      tags: ["Physics", "Raycasting"],
    },
  ],

  // Proceso / decisiones de diseño
  process: [
    {
      phase: "01 — Concepto",
      title: "Punto de partida",
      body: "Cómo surgió la idea, cuál era el objetivo inicial y qué referencias tomaste.",
    },
    {
      phase: "02 — Prototipado",
      title: "Primera iteración",
      body: "Qué prototipaste primero, qué funcionó y qué descartaste. Las decisiones tempranas importantes.",
    },
    {
      phase: "03 — Desarrollo",
      title: "Construyendo el sistema",
      body: "Cómo evolucionó el proyecto, qué cambió respecto al concepto inicial y por qué.",
    },
    {
      phase: "04 — Pulido",
      title: "Iteración final",
      body: "Qué ajustes marcaron la diferencia al final del proceso.",
    },
  ],

  // Retos y soluciones
  challenges: [
    {
      problem: "Describe el problema técnico o de diseño que encontraste.",
      solution: "Cómo lo resolviste. Sé específico con el enfoque técnico que usaste.",
      tag: "Técnico",
    },
    {
      problem: "Otro reto que te encontraste durante el desarrollo.",
      solution: "Tu solución, qué aprendiste de ello.",
      tag: "Diseño",
    },
    {
      problem: "Tercer reto si lo hubo.",
      solution: "Resolución.",
      tag: "Rendimiento",
    },
  ],

  // Aprendizajes clave (opcional)
  learnings: [
    "Algo concreto que aprendiste técnicamente.",
    "Una lección sobre proceso o diseño de juegos.",
    "Algo que harías diferente si lo empezaras de nuevo.",
  ],

  // Links
  links: {
    github: "https://github.com/Toto-RR/tu-proyecto",
    demo: null,
    youtube: null,
    itch: null,
  },

  // Proyecto anterior / siguiente (para navegación)
  prev: { title: "Proyecto Anterior", slug: "/projects/otro-proyecto" },
  next: { title: "Proyecto Siguiente", slug: "/projects/otro-proyecto-2" },
};
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{project.title} · Toni Romanos</title>
  <meta name="description" content={project.tagline} />

  <!-- Fuente del portfolio principal -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ── Variables globales del portfolio ── */
    :root {
      --bg:            #0b0b0c;
      --bg-soft:       #121214;
      --panel:         rgba(255,255,255,0.04);
      --text:          #f4f4f5;
      --muted:         #a1a1aa;
      --line:          rgba(255,255,255,0.08);
      --radius:        20px;
      --radius-lg:     28px;
      --shadow:        0 20px 60px rgba(0,0,0,0.35);
      --shadow-soft:   0 14px 40px rgba(0,0,0,0.24);
      --container:     1100px;

      /* ── Color de acento POR PROYECTO — cambia estas dos ── */
      --pa:            /* accent color injected below via style attr */;
      --pa-soft:       /* accent-soft injected below */;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: "Sora", system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }
    img, video { display: block; max-width: 100%; }
    strong { color: var(--pa, #f51a29); }

    .container {
      width: min(var(--container), calc(100% - 2rem));
      margin: 0 auto;
    }

    /* ══════════════════════════════════════════
       BACK NAV
    ══════════════════════════════════════════ */
    .back-nav {
      position: fixed;
      top: 1.5rem;
      left: 1.5rem;
      z-index: 50;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.6rem 1rem;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(11,11,12,0.72);
      backdrop-filter: blur(12px);
      color: var(--muted);
      font-size: 0.84rem;
      font-weight: 600;
      transition: color 0.2s, border-color 0.2s, transform 0.2s;
    }

    .back-btn:hover {
      color: var(--text);
      border-color: rgba(255,255,255,0.18);
      transform: translateX(-2px);
    }

    .back-btn svg {
      width: 14px;
      height: 14px;
    }

    /* ══════════════════════════════════════════
       HERO
    ══════════════════════════════════════════ */
    .project-hero {
      position: relative;
      min-height: 92svh;
      display: grid;
      place-items: end;
      overflow: hidden;
      isolation: isolate;
    }

    .project-hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .project-hero-bg img,
    .project-hero-bg video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .project-hero-overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        linear-gradient(to top, rgba(11,11,12,0.98) 0%, rgba(11,11,12,0.6) 40%, rgba(11,11,12,0.2) 100%),
        linear-gradient(to right, rgba(11,11,12,0.55) 0%, transparent 60%);
    }

    /* Glow de acento detrás del texto */
    .project-hero-glow {
      position: absolute;
      bottom: -80px;
      left: -80px;
      width: 500px;
      height: 500px;
      border-radius: 999px;
      background: radial-gradient(circle, var(--pa-soft, rgba(245,26,41,0.14)), transparent 68%);
      filter: blur(40px);
      z-index: 1;
      pointer-events: none;
    }

    .project-hero-inner {
      position: relative;
      z-index: 2;
      width: 100%;
      padding: 0 0 5rem;
    }

    .project-hero-content {
      max-width: 820px;
    }

    .project-hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.2rem;
      color: var(--pa, #f51a29);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .project-hero-eyebrow-line {
      width: 36px;
      height: 1px;
      background: currentColor;
      opacity: 0.6;
    }

    .project-hero h1 {
      font-size: clamp(3rem, 8vw, 6.5rem);
      font-weight: 700;
      line-height: 0.93;
      letter-spacing: -0.05em;
      margin-bottom: 1.5rem;
    }

    .project-hero-tagline {
      max-width: 58ch;
      color: rgba(255,255,255,0.82);
      line-height: 1.72;
      font-size: clamp(1rem, 1.5vw, 1.15rem);
      margin-bottom: 2rem;
    }

    .project-hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      margin-bottom: 2rem;
    }

    .project-meta-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.5rem 0.9rem;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.04);
      font-size: 0.8rem;
      color: var(--muted);
    }

    .project-meta-pill strong {
      color: var(--text);
      font-weight: 600;
    }

    .project-hero-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-bottom: 2.5rem;
    }

    .project-tag {
      padding: 0.45rem 0.85rem;
      border-radius: 10px;
      border: 1px solid var(--pa-soft, rgba(245,26,41,0.14));
      background: rgba(255,255,255,0.04);
      color: var(--text);
      font-size: 0.8rem;
      font-weight: 600;
      backdrop-filter: blur(6px);
    }

    .project-hero-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .project-link-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      min-height: 46px;
      padding: 0 1.2rem;
      border-radius: 999px;
      border: 1px solid var(--line);
      font-size: 0.88rem;
      font-weight: 700;
      transition: transform 0.2s, border-color 0.2s, background 0.2s, box-shadow 0.2s;
    }

    .project-link-btn:hover {
      transform: translateY(-2px);
    }

    .project-link-btn--primary {
      background: linear-gradient(180deg, color-mix(in srgb, var(--pa, #f51a29) 80%, white), var(--pa, #f51a29));
      border-color: var(--pa, #f51a29);
      color: #fff;
      box-shadow: 0 12px 30px color-mix(in srgb, var(--pa, #f51a29) 30%, transparent);
    }

    .project-link-btn--primary:hover {
      box-shadow: 0 18px 40px color-mix(in srgb, var(--pa, #f51a29) 40%, transparent);
    }

    .project-link-btn--ghost {
      background: rgba(255,255,255,0.04);
      color: var(--text);
    }

    .project-link-btn--ghost:hover {
      border-color: rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.07);
    }

    /* Scroll indicator */
    .project-hero-scroll {
      position: absolute;
      bottom: 2rem;
      right: 2rem;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .project-hero-scroll-line {
      width: 1px;
      height: 48px;
      background: linear-gradient(to bottom, var(--pa, #f51a29), transparent);
      animation: scroll-line 2s ease infinite;
    }

    @keyframes scroll-line {
      0%   { transform: scaleY(0); transform-origin: top; }
      50%  { transform: scaleY(1); transform-origin: top; }
      51%  { transform: scaleY(1); transform-origin: bottom; }
      100% { transform: scaleY(0); transform-origin: bottom; }
    }

    /* ══════════════════════════════════════════
       SECCIÓN WRAPPER
    ══════════════════════════════════════════ */
    .project-section {
      padding: 6rem 0;
    }

    .project-section + .project-section {
      padding-top: 0;
    }

    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .section-label-line {
      width: 36px;
      height: 1px;
      background: linear-gradient(90deg, var(--pa, #f51a29), transparent);
    }

    .section-title {
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      line-height: 1.02;
      letter-spacing: -0.04em;
      margin-bottom: 0.75rem;
    }

    .section-subtitle {
      color: var(--muted);
      line-height: 1.72;
      max-width: 68ch;
    }

    /* ══════════════════════════════════════════
       DESCRIPCIÓN
    ══════════════════════════════════════════ */
    .project-desc-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
      gap: 3rem;
      align-items: start;
      margin-top: 3rem;
    }

    .project-desc-body {
      color: rgba(255,255,255,0.82);
      line-height: 1.8;
      font-size: 1.05rem;
    }

    .project-desc-body p + p {
      margin-top: 1.2rem;
    }

    .project-info-card {
      position: sticky;
      top: 2rem;
      padding: 1.5rem;
      border-radius: var(--radius-lg);
      border: 1px solid var(--line);
      background:
        radial-gradient(circle at top right, var(--pa-soft, rgba(245,26,41,0.1)), transparent 55%),
        linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.02));
    }

    .project-info-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
      padding: 0.9rem 0;
      border-bottom: 1px solid var(--line);
    }

    .project-info-row:last-child {
      border-bottom: none;
    }

    .project-info-label {
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      flex-shrink: 0;
    }

    .project-info-value {
      color: var(--text);
      font-size: 0.95rem;
      font-weight: 600;
      text-align: right;
    }

    .project-status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.3rem 0.7rem;
      border-radius: 999px;
      border: 1px solid var(--pa-soft, rgba(245,26,41,0.2));
      background: var(--pa-soft, rgba(245,26,41,0.08));
      color: #ffd6da;
      font-size: 0.78rem;
      font-weight: 700;
    }

    .project-status-dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: var(--pa, #f51a29);
    }

    /* ══════════════════════════════════════════
       GALERÍA
    ══════════════════════════════════════════ */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1rem;
      margin-top: 3rem;
    }

    /* Alterna tamaños para que no sea una cuadrícula aburrida */
    .gallery-item {
      grid-column: span 6;
      position: relative;
      overflow: hidden;
      border-radius: var(--radius);
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
      aspect-ratio: 16 / 10;
      cursor: zoom-in;
    }

    .gallery-item:nth-child(3n+1) {
      grid-column: span 8;
    }

    .gallery-item:nth-child(3n+2) {
      grid-column: span 4;
    }

    .gallery-item img,
    .gallery-item video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .gallery-item:hover img,
    .gallery-item:hover video {
      transform: scale(1.03);
    }

    .gallery-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 0.75rem 1rem;
      background: linear-gradient(to top, rgba(11,11,12,0.9), transparent);
      color: var(--muted);
      font-size: 0.82rem;
      opacity: 0;
      transform: translateY(4px);
      transition: opacity 0.25s, transform 0.25s;
    }

    .gallery-item:hover .gallery-caption {
      opacity: 1;
      transform: translateY(0);
    }

    /* Lightbox */
    .lightbox {
      position: fixed;
      inset: 0;
      z-index: 100;
      background: rgba(5,5,7,0.96);
      display: flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(12px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s;
    }

    .lightbox.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    .lightbox-media {
      max-width: 90vw;
      max-height: 88vh;
      border-radius: var(--radius);
      border: 1px solid var(--line);
    }

    .lightbox-close {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
      width: 44px;
      height: 44px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.06);
      color: var(--text);
      font-size: 1.2rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }

    .lightbox-close:hover { background: rgba(255,255,255,0.12); }

    /* ══════════════════════════════════════════
       SISTEMAS TÉCNICOS
    ══════════════════════════════════════════ */
    .systems-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.25rem;
      margin-top: 3rem;
    }

    .system-card {
      position: relative;
      overflow: hidden;
      padding: 1.5rem;
      border-radius: var(--radius-lg);
      border: 1px solid var(--line);
      background:
        radial-gradient(circle at top right, var(--pa-soft, rgba(245,26,41,0.08)), transparent 55%),
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
      transition: transform 0.25s, border-color 0.25s;
    }

    .system-card::before {
      content: "";
      position: absolute;
      top: -1px;
      left: 1.5rem;
      right: 1.5rem;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--pa, #f51a29), transparent);
      opacity: 0;
      transition: opacity 0.25s;
    }

    .system-card:hover {
      transform: translateY(-4px);
      border-color: color-mix(in srgb, var(--pa, #f51a29) 30%, transparent);
    }

    .system-card:hover::before {
      opacity: 1;
    }

    .system-number {
      font-size: 3rem;
      font-weight: 700;
      line-height: 1;
      letter-spacing: -0.06em;
      color: var(--pa-soft, rgba(245,26,41,0.2));
      margin-bottom: 0.75rem;
      font-variant-numeric: tabular-nums;
    }

    .system-card h3 {
      font-size: 1.2rem;
      letter-spacing: -0.02em;
      margin-bottom: 0.75rem;
    }

    .system-card p {
      color: var(--muted);
      line-height: 1.72;
      font-size: 0.95rem;
      margin-bottom: 1.25rem;
    }

    .system-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .system-tag {
      padding: 0.3rem 0.65rem;
      border-radius: 8px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.04);
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 600;
    }

    /* ══════════════════════════════════════════
       PROCESO
    ══════════════════════════════════════════ */
    .process-timeline {
      position: relative;
      margin-top: 3rem;
    }

    .process-timeline::before {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      left: 1.5rem;
      width: 1px;
      background: linear-gradient(to bottom, var(--pa, #f51a29), rgba(255,255,255,0.06));
    }

    .process-step {
      display: grid;
      grid-template-columns: 3rem 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
      align-items: start;
    }

    .process-step:last-child {
      margin-bottom: 0;
    }

    .process-dot-wrap {
      display: flex;
      justify-content: center;
      padding-top: 1.6rem;
      position: relative;
      z-index: 1;
    }

    .process-dot {
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background: var(--pa, #f51a29);
      box-shadow:
        0 0 0 5px rgba(11,11,12,1),
        0 0 0 7px color-mix(in srgb, var(--pa, #f51a29) 30%, transparent);
    }

    .process-card {
      padding: 1.5rem 1.5rem 1.35rem;
      border-radius: var(--radius-lg);
      border: 1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
      transition: transform 0.25s, border-color 0.25s;
    }

    .process-card:hover {
      transform: translateY(-3px);
      border-color: color-mix(in srgb, var(--pa, #f51a29) 25%, transparent);
    }

    .process-phase {
      color: var(--pa, #f51a29);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .process-card h3 {
      font-size: clamp(1.2rem, 2vw, 1.6rem);
      letter-spacing: -0.03em;
      margin-bottom: 0.85rem;
    }

    .process-card p {
      color: var(--muted);
      line-height: 1.75;
    }

    /* ══════════════════════════════════════════
       RETOS
    ══════════════════════════════════════════ */
    .challenges-list {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-top: 3rem;
    }

    .challenge-card {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 0;
      border-radius: var(--radius-lg);
      border: 1px solid var(--line);
      overflow: hidden;
      transition: border-color 0.25s;
    }

    .challenge-card:hover {
      border-color: color-mix(in srgb, var(--pa, #f51a29) 28%, transparent);
    }

    .challenge-problem,
    .challenge-solution {
      padding: 1.5rem;
    }

    .challenge-problem {
      background: rgba(255,255,255,0.025);
      border-right: 1px solid var(--line);
    }

    .challenge-solution {
      background:
        radial-gradient(circle at bottom left, var(--pa-soft, rgba(245,26,41,0.08)), transparent 60%),
        rgba(255,255,255,0.02);
    }

    .challenge-label {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-bottom: 0.85rem;
      padding: 0.3rem 0.65rem;
      border-radius: 8px;
      font-size: 0.74rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .challenge-label--problem {
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.05);
      color: var(--muted);
    }

    .challenge-label--solution {
      border: 1px solid color-mix(in srgb, var(--pa, #f51a29) 30%, transparent);
      background: var(--pa-soft, rgba(245,26,41,0.08));
      color: #ffd6da;
    }

    .challenge-tag {
      float: right;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.04);
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 600;
    }

    .challenge-problem p,
    .challenge-solution p {
      color: rgba(255,255,255,0.82);
      line-height: 1.72;
      font-size: 0.95rem;
    }

    /* ══════════════════════════════════════════
       APRENDIZAJES
    ══════════════════════════════════════════ */
    .learnings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1rem;
      margin-top: 3rem;
    }

    .learning-card {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      padding: 1.25rem;
      border-radius: var(--radius);
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
      transition: transform 0.2s, border-color 0.2s;
    }

    .learning-card:hover {
      transform: translateY(-3px);
      border-color: color-mix(in srgb, var(--pa, #f51a29) 25%, transparent);
    }

    .learning-icon {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--pa, #f51a29);
      flex-shrink: 0;
      margin-top: 0.45rem;
    }

    .learning-card p {
      color: rgba(255,255,255,0.82);
      line-height: 1.68;
      font-size: 0.95rem;
    }

    /* ══════════════════════════════════════════
       NAVEGACIÓN PREV / NEXT
    ══════════════════════════════════════════ */
    .project-nav {
      padding: 5rem 0 6rem;
      border-top: 1px solid var(--line);
      margin-top: 2rem;
    }

    .project-nav-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .project-nav-link {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.5rem;
      border-radius: var(--radius-lg);
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
      transition: transform 0.25s, border-color 0.25s, background 0.25s;
    }

    .project-nav-link:hover {
      transform: translateY(-3px);
      border-color: color-mix(in srgb, var(--pa, #f51a29) 28%, transparent);
      background: rgba(255,255,255,0.05);
    }

    .project-nav-link--next {
      text-align: right;
    }

    .project-nav-direction {
      color: var(--muted);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .project-nav-title {
      font-size: clamp(1.1rem, 2vw, 1.45rem);
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    /* ══════════════════════════════════════════
       RESPONSIVE
    ══════════════════════════════════════════ */
    @media (max-width: 900px) {
      .project-desc-grid { grid-template-columns: 1fr; }
      .project-info-card { position: static; }
      .challenge-card { grid-template-columns: 1fr; }
      .challenge-problem { border-right: none; border-bottom: 1px solid var(--line); }
    }

    @media (max-width: 720px) {
      .gallery-grid { grid-template-columns: 1fr 1fr; }
      .gallery-item,
      .gallery-item:nth-child(3n+1),
      .gallery-item:nth-child(3n+2) { grid-column: span 1; }
      .project-nav-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 540px) {
      .project-hero h1 { font-size: clamp(2.5rem, 11vw, 4rem); }
      .gallery-grid { grid-template-columns: 1fr; }
      .gallery-item { aspect-ratio: 16 / 10; }
      .process-timeline::before { left: 1rem; }
      .process-step { grid-template-columns: 2.2rem 1fr; gap: 1rem; }
    }
  </style>
</head>

<body style={`--pa: ${project.accent}; --pa-soft: ${project.accentSoft};`}>

  <!-- Back button -->
  <nav class="back-nav">
    <a href="/#projects" class="back-btn">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M10 3L5 8l5 5"/>
      </svg>
      Volver
    </a>
  </nav>

  <!-- ═══ HERO ═══════════════════════════════════════════════════════════ -->
  <header class="project-hero">
    <div class="project-hero-bg">
      {project.coverVideo ? (
        <video src={project.coverVideo} autoplay muted loop playsinline />
      ) : (
        <img src={project.cover} alt={project.title} />
      )}
    </div>
    <div class="project-hero-overlay"></div>
    <div class="project-hero-glow"></div>

    <div class="project-hero-inner">
      <div class="container">
        <div class="project-hero-content">

          <p class="project-hero-eyebrow">
            <span class="project-hero-eyebrow-line"></span>
            {project.subtitle}
          </p>

          <h1>{project.title}</h1>

          <p class="project-hero-tagline">{project.tagline}</p>

          <div class="project-hero-meta">
            <span class="project-meta-pill"><strong>{project.year}</strong></span>
            <span class="project-meta-pill">{project.duration}</span>
            <span class="project-meta-pill">{project.role}</span>
            <span class="project-meta-pill">{project.team}</span>
          </div>

          <div class="project-hero-tags">
            {project.tags.map(t => <span class="project-tag">{t}</span>)}
          </div>

          <div class="project-hero-links">
            {project.links.demo && (
              <a href={project.links.demo} class="project-link-btn project-link-btn--primary" target="_blank" rel="noopener noreferrer">
                Ver proyecto
              </a>
            )}
            {project.links.github && (
              <a href={project.links.github} class="project-link-btn project-link-btn--ghost" target="_blank" rel="noopener noreferrer">
                GitHub
              </a>
            )}
            {project.links.youtube && (
              <a href={project.links.youtube} class="project-link-btn project-link-btn--ghost" target="_blank" rel="noopener noreferrer">
                YouTube
              </a>
            )}
            {project.links.itch && (
              <a href={project.links.itch} class="project-link-btn project-link-btn--ghost" target="_blank" rel="noopener noreferrer">
                itch.io
              </a>
            )}
          </div>

        </div>
      </div>
    </div>

    <div class="project-hero-scroll">
      <div class="project-hero-scroll-line"></div>
      <span>scroll</span>
    </div>
  </header>

  <main>

    <!-- ═══ DESCRIPCIÓN ════════════════════════════════════════════════════ -->
    <section class="project-section">
      <div class="container">
        <div class="section-label">
          <span class="section-label-line"></span>
          Sobre el proyecto
        </div>
        <div class="project-desc-grid">
          <div class="project-desc-body" set:html={project.description} />

          <aside class="project-info-card">
            <div class="project-info-row">
              <span class="project-info-label">Año</span>
              <span class="project-info-value">{project.year}</span>
            </div>
            <div class="project-info-row">
              <span class="project-info-label">Duración</span>
              <span class="project-info-value">{project.duration}</span>
            </div>
            <div class="project-info-row">
              <span class="project-info-label">Rol</span>
              <span class="project-info-value">{project.role}</span>
            </div>
            <div class="project-info-row">
              <span class="project-info-label">Equipo</span>
              <span class="project-info-value">{project.team}</span>
            </div>
            <div class="project-info-row">
              <span class="project-info-label">Estado</span>
              <span class="project-info-value">
                <span class="project-status-badge">
                  <span class="project-status-dot"></span>
                  {project.status}
                </span>
              </span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ═══ GALERÍA ════════════════════════════════════════════════════════ -->
    {project.gallery.length > 0 && (
      <section class="project-section">
        <div class="container">
          <div class="section-label">
            <span class="section-label-line"></span>
            Galería
          </div>
          <h2 class="section-title">Imágenes y gameplay</h2>

          <div class="gallery-grid" id="gallery">
            {project.gallery.map((item, i) => (
              <div
                class="gallery-item"
                data-lightbox
                data-src={item.src}
                data-type={item.type}
              >
                {item.type === "video" ? (
                  <video src={item.src} muted loop playsinline preload="metadata" />
                ) : (
                  <img src={item.src} alt={item.caption || `Imagen ${i + 1}`} loading="lazy" />
                )}
                {item.caption && (
                  <p class="gallery-caption">{item.caption}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ SISTEMAS TÉCNICOS ══════════════════════════════════════════════ -->
    {project.systems.length > 0 && (
      <section class="project-section">
        <div class="container">
          <div class="section-label">
            <span class="section-label-line"></span>
            Arquitectura
          </div>
          <h2 class="section-title">Sistemas técnicos</h2>
          <p class="section-subtitle">Cómo está construido por dentro: decisiones de arquitectura y los sistemas que dan vida al proyecto.</p>

          <div class="systems-grid">
            {project.systems.map((sys, i) => (
              <article class="system-card">
                <div class="system-number">0{i + 1}</div>
                <h3>{sys.title}</h3>
                <p>{sys.description}</p>
                <div class="system-tags">
                  {sys.tags.map(t => <span class="system-tag">{t}</span>)}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ PROCESO ════════════════════════════════════════════════════════ -->
    {project.process.length > 0 && (
      <section class="project-section">
        <div class="container">
          <div class="section-label">
            <span class="section-label-line"></span>
            Proceso
          </div>
          <h2 class="section-title">Cómo se construyó</h2>
          <p class="section-subtitle">Las fases del proyecto: desde la idea hasta el resultado final.</p>

          <div class="process-timeline">
            {project.process.map((step) => (
              <div class="process-step">
                <div class="process-dot-wrap">
                  <span class="process-dot"></span>
                </div>
                <article class="process-card">
                  <p class="process-phase">{step.phase}</p>
                  <h3>{step.title}</h3>
                  <p>{step.body}</p>
                </article>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ RETOS ═══════════════════════════════════════════════════════════ -->
    {project.challenges.length > 0 && (
      <section class="project-section">
        <div class="container">
          <div class="section-label">
            <span class="section-label-line"></span>
            Retos
          </div>
          <h2 class="section-title">Problemas y soluciones</h2>
          <p class="section-subtitle">Los obstáculos más interesantes del proyecto y cómo los resolví.</p>

          <div class="challenges-list">
            {project.challenges.map((c) => (
              <div class="challenge-card">
                <div class="challenge-problem">
                  <div>
                    <span class="challenge-tag">{c.tag}</span>
                    <span class="challenge-label challenge-label--problem">Problema</span>
                  </div>
                  <p>{c.problem}</p>
                </div>
                <div class="challenge-solution">
                  <span class="challenge-label challenge-label--solution">Solución</span>
                  <p>{c.solution}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ APRENDIZAJES ═══════════════════════════════════════════════════ -->
    {project.learnings && project.learnings.length > 0 && (
      <section class="project-section">
        <div class="container">
          <div class="section-label">
            <span class="section-label-line"></span>
            Conclusiones
          </div>
          <h2 class="section-title">Qué aprendí</h2>

          <div class="learnings-grid">
            {project.learnings.map((l) => (
              <div class="learning-card">
                <span class="learning-icon"></span>
                <p>{l}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <!-- ═══ NAV PREV / NEXT ════════════════════════════════════════════════ -->
  <div class="container">
    <nav class="project-nav">
      <div class="project-nav-grid">
        {project.prev && (
          <a href={project.prev.slug} class="project-nav-link project-nav-link--prev">
            <span class="project-nav-direction">← Anterior</span>
            <span class="project-nav-title">{project.prev.title}</span>
          </a>
        )}
        {project.next && (
          <a href={project.next.slug} class="project-nav-link project-nav-link--next" style={project.prev ? "" : "grid-column: 2"}>
            <span class="project-nav-direction">Siguiente →</span>
            <span class="project-nav-title">{project.next.title}</span>
          </a>
        )}
      </div>
    </nav>
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Imagen ampliada">
    <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar">✕</button>
    <img class="lightbox-media" id="lightbox-img" src="" alt="" style="display:none" />
    <video class="lightbox-media" id="lightbox-video" src="" autoplay muted loop playsinline style="display:none" />
  </div>

  <script lang="ts">
    // ── Lightbox ──────────────────────────────────────────────────────────
    const lightbox     = document.getElementById("lightbox");
    const lbImg        = document.getElementById("lightbox-img");
    const lbVideo      = document.getElementById("lightbox-video");
    const lbClose      = document.getElementById("lightbox-close");
    const galleryItems = document.querySelectorAll("[data-lightbox]");

    const openLightbox = (src, type) => {
      if (type === "video") {
        lbVideo.src = src;
        lbVideo.style.display = "block";
        lbImg.style.display   = "none";
      } else {
        lbImg.src             = src;
        lbImg.style.display   = "block";
        lbVideo.style.display = "none";
      }
      lightbox.classList.add("is-open");
      document.body.style.overflow = "hidden";
    };

    const closeLightbox = () => {
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
      lbVideo.src = "";
    };

    galleryItems.forEach(item => {
      item.addEventListener("click", () =>
        openLightbox(item.dataset.src, item.dataset.type)
      );
    });

    lbClose.addEventListener("click", closeLightbox);
    lightbox.addEventListener("click", e => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener("keydown", e => { if (e.key === "Escape") closeLightbox(); });

    // ── Play vídeo de galería al hover ───────────────────────────────────
    document.querySelectorAll(".gallery-item video").forEach(video => {
      const parent = video.closest(".gallery-item");
      parent.addEventListener("mouseenter", () => video.play().catch(() => {}));
      parent.addEventListener("mouseleave", () => { video.pause(); video.currentTime = 0; });
    });
  </script>

</body>
</html>