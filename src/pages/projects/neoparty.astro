---
import Layout from "../../layouts/Layout.astro";
import GitHub from "../../components/icons/GitHub.astro";
import Link from "../../components/icons/Link.astro";
import Youtube from "../../components/icons/Youtube.astro";
import LinkButton from "../../components/LinkButton.astro";

import { joinedNeoParty as project } from "../../data/projects/neoparty";

type MediaItem = {
  type: "image" | "video" | "youtube";
  src: string;
  title?: string;
  description?: string;
};

type CodeSnippet = {
  title: string;
  language?: string;
  code: string;
  description?: string;
};

const media: MediaItem[] = project.detail?.media ?? project.gallery ?? [];
const snippets: CodeSnippet[] = project.detail?.codeSnippets ?? [];
const recognitions: string[] = project.detail?.recognitions ?? [];
const technologies = project.detail?.technologies ?? project.tags ?? [];
const cleanDescription = project.description
  .replace(/<[^>]+>/g, "")
  .slice(0, 160);
---

<style>
  :global(.project-rich-text p + p) {
    margin-top: 1.25rem;
  }

  :global(.project-rich-text p) {
    line-height: 1.7;
  }

  :global(.project-rich-text strong) {
    color: #38bdf8;
    font-weight: 700;
  }

  :global(.project-rich-text ul) {
    margin-top: 1rem;
    padding-left: 1.25rem;
    list-style: disc;
  }

  :global(.project-rich-text li + li) {
    margin-top: 0.5rem;
  }

  :global(.role-text p + p) {
    margin-top: 1rem;
  }

  :global(.role-text strong) {
    color: #38bdf8;
  }

  :global(.role-text ul) {
    margin-top: 1rem;
    padding-left: 1.25rem;
    list-style: disc;
  }

  :global(.role-text li + li) {
    margin-top: 0.5rem;
  }

  .section-card {
    border: 1px solid rgb(55 65 81 / 1);
    border-radius: 1rem;
    padding: 1.5rem;
    background: rgb(3 7 18 / 0.35);
    backdrop-filter: blur(4px);
  }

  .code-block {
    margin-top: 1rem;
    overflow-x: auto;
    border-radius: 0.9rem;
    border: 1px solid rgb(55 65 81 / 1);
    background: rgb(2 6 23 / 1);
  }

  .code-block pre {
    margin: 0;
    padding: 1rem 1.25rem;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .media-caption p + p {
    margin-top: 0.75rem;
  }

  @media (max-width: 768px) {
    .section-card {
      padding: 0.9rem;
      border-radius: 0.85rem;
    }

    .code-block pre {
      padding: 0.85rem 1rem;
      font-size: 0.82rem;
      line-height: 1.5;
    }
  }
</style>

<Layout
  title={project.title}
  description={`Detalles del proyecto ${project.title}. ${cleanDescription}...`}
  headerVariant="minimal"
>
  <main
    class="max-w-7xl mx-auto px-4 sm:px-6 md:px-10 lg:px-16 py-8 sm:py-10 md:py-12 space-y-12 sm:space-y-16 md:space-y-20"
  >
    <!-- HERO -->
    <section class="space-y-8">
      <div class="space-y-3 sm:space-y-4 text-center">
        <p
          class="uppercase tracking-[0.2em] sm:tracking-[0.3em] text-xs sm:text-sm text-cyan-300"
        >
          Proyecto destacado
        </p>
        <h1
          class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-yellow-200 leading-tight"
        >
          {project.title}
        </h1>
      </div>

      <div class="max-w-6xl mx-auto space-y-6 sm:space-y-8">
        <div class="section-card">
          {
            project.youtubeVideoId ? (
              <div class="aspect-video overflow-hidden rounded-xl">
                <iframe
                  class="w-full h-full"
                  src={`https://www.youtube-nocookie.com/embed/${project.youtubeVideoId}`}
                  title={`Trailer ${project.title}`}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              </div>
            ) : project.trailer ? (
              <div class="aspect-video overflow-hidden rounded-xl">
                <video
                  class="w-full h-full object-cover rounded-xl"
                  controls
                  playsinline
                  preload="metadata"
                  poster={project.image}
                >
                  <source src={project.trailer} type="video/mp4" />
                </video>
              </div>
            ) : (
              <img
                src={project.image}
                alt={`Imagen principal del proyecto ${project.title}`}
                class="w-full h-auto rounded-xl object-cover"
              />
            )
          }
        </div>

        <aside class="section-card space-y-6">
          <div
            class="project-rich-text text-base sm:text-lg text-gray-200"
            set:html={project.description}
          />

          <div class="space-y-3">
            <h2 class="text-2xl sm:text-3xl font-bold text-cyan-200">
              Tecnologías
            </h2>
            <ul class="flex flex-wrap gap-2">
              {
                technologies.map((tag: any) => (
                  <li>
                    <span
                      class={`inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm ${tag.class}`}
                    >
                      <tag.icon class="size-4" />
                      {tag.name}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="flex flex-wrap gap-4 pt-2">
            {
              project.github && (
                <LinkButton href={project.github}>
                  <GitHub class="size-5" />
                  Código
                </LinkButton>
              )
            }

            {
              project.link && (
                <LinkButton href={project.link}>
                  <Link class="size-4" />
                  Web
                </LinkButton>
              )
            }

            {
              project.youtubeVideoId && (
                <LinkButton
                  href={`https://www.youtube.com/watch?v=${project.youtubeVideoId}`}
                >
                  <Youtube class="size-5" />
                  Trailer
                </LinkButton>
              )
            }
          </div>
        </aside>
      </div>
    </section>

    <!-- INFORMACIÓN + ROL -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8">
      {
        project.detail?.explication && (
          <div class="section-card space-y-5">
            <h2 class="text-2xl sm:text-3xl font-bold text-cyan-200">
              Sobre el proyecto
            </h2>

            <div class="project-rich-text text-base sm:text-lg text-gray-300 space-y-4">
              {project.detail.explication.map((paragraph: string) => (
                <div set:html={paragraph} />
              ))}
            </div>
          </div>
        )
      }

      {
        project.detail?.myRole && (
          <div class="section-card space-y-5">
            <h2 class="text-2xl sm:text-3xl font-bold text-cyan-200">Mi rol</h2>

            <div
              class="role-text text-base sm:text-lg text-gray-300 leading-relaxed py-1 sm:py-2"
              set:html={project.detail.myRole}
            />
          </div>
        )
      }
    </section>

    <!-- RECONOCIMIENTOS -->
    {
      recognitions.length > 0 && (
        <section class="section-card space-y-5">
          <h2 class="text-2xl sm:text-3xl font-bold text-cyan-200">
            Reconocimientos
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {recognitions.map((item) => (
              <div class="rounded-xl border border-gray-700 bg-slate-950/50 p-4 text-gray-200 leading-relaxed">
                {item}
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- GALERÍA -->
    {
      media.length > 0 && (
        <section class="space-y-8">
          <div class="text-center space-y-2">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-cyan-200">
              Galería multimedia
            </h2>
            <p class="text-sm sm:text-base text-gray-400">
              Capturas, vídeos, material de presentación y otros recursos del
              proyecto.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5 sm:gap-6 lg:gap-8 items-start">
            {media.map((item) => (
              <article class="section-card space-y-4 self-start">
                {item.title && (
                  <h3 class="text-lg sm:text-xl font-semibold text-yellow-200">
                    {item.title}
                  </h3>
                )}

                {item.type === "image" && (
                  <img
                    src={item.src}
                    alt={item.title ?? "Media del proyecto"}
                    class="w-full rounded-xl"
                    loading="lazy"
                  />
                )}

                {item.type === "video" && (
                  <video class="w-full rounded-xl" controls preload="metadata">
                    <source src={item.src} type="video/mp4" />
                  </video>
                )}

                {item.type === "youtube" && (
                  <div class="aspect-video">
                    <iframe
                      class="w-full h-full rounded-xl"
                      src={`https://www.youtube-nocookie.com/embed/${item.src}`}
                      title={item.title ?? "Vídeo del proyecto"}
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    />
                  </div>
                )}

                {item.description && (
                  <div class="media-caption text-sm sm:text-base text-gray-400 leading-relaxed">
                    <p>{item.description}</p>
                  </div>
                )}
              </article>
            ))}
          </div>
        </section>
      )
    }

    <!-- SNIPPETS -->
    {
      snippets.length > 0 && (
        <section class="space-y-8">
          <div class="text-center space-y-2">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-cyan-200">
              Snippets de código
            </h2>
            <p class="text-sm sm:text-base text-gray-400">
              Fragmentos concretos que muestran partes técnicas relevantes del
              proyecto.
            </p>
          </div>

          <div class="space-y-8">
            {snippets.map((snippet) => (
              <article class="section-card">
                <div class="space-y-2">
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                    <h3 class="text-xl sm:text-2xl font-semibold text-yellow-200">
                      {snippet.title}
                    </h3>
                    {snippet.language && (
                      <span class="w-fit rounded-full border border-cyan-700 px-3 py-1 text-sm text-cyan-300">
                        {snippet.language}
                      </span>
                    )}
                  </div>

                  {snippet.description && (
                    <p class="text-sm sm:text-base text-gray-400 leading-relaxed">
                      {snippet.description}
                    </p>
                  )}
                </div>

                <div class="code-block">
                  <pre>
                    <code>{snippet.code}</code>
                  </pre>
                </div>
              </article>
            ))}
          </div>
        </section>
      )
    }
  </main>
</Layout>
