---
const { href } = Astro.props;
---

<a
    target="_blank"
    href={href}
    role="link"
    class="
    inline-flex 
    bg-gray-100 
    text-gray-800 
    border-gray-300 
    items-center 
    justify-center 
    gap-2 
    px-3 
    py-2 
    space-x-2 
    text-base 
    transition 
    dark:text-white 
    dark:bg-gray-800 
    border 
    dark:border-gray-600 
    focus-visible:ring-yellow-500/80 
    text-md hover:bg-gray-800 
    group 
    max-w-fit 
    rounded-xl 
    transition hover:transform hover:scale-[1.05] bg-gray-100 hover:bg-gray-200 focus:bg-gray-800 dark:bg-gray-800 dark:hover:bg-gray-700 dark:focus:bg-gray-700
    focus:outline-none 
    focus-visible:outline-none 
    focus-visible:ring 
    focus-visible:ring-white 
    focus-visible:ring-offset-2 
    active:bg-black"
>
    <slot />
</a>
