---
import GitHub from "./icons/GitHub.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";

import { OTHER_PROJECTS } from "@/data/projects";

const PROJECTS = [
  {
    slug: "joined-neoparty",
    title: "NIGHTMARES OF THE NIGHT",
    github: "https://github.com/ericlr1/7a-Gran-CITM-Game-Jam",
    description:
      "Un juego hecho en <strong>Unity</strong> para la <strong>7a Gran CITM Game Jam</strong> junto a 5 compañeros, en el que la temática era <strong>'Sueños y Pesadillas'</strong>.",
    image: "./projects/nightmaresofthenight.webp",
    icon: GitHub,
  },
  {
    title: "DRAGGED OFF TIME",
    github: "https://github.com/francesctr4/Nexus-Studios",
    description:
      "Un <strong>RPG con elementos Roguelike</strong> ambientado en diferentes épocas. Hecho a partir de <strong>C++ con SDL</strong> por un grupo de <strong>10 personas</strong>.",
    image: "./projects/DOTLogo.webp",
    icon: GitHub,
  },
  {
    title: "CITM FIGHTERS",
    description:
      "Juego de lucha en vista lateral hecho en <strong>Unity</strong>, modelos de <strong>Sketchfab</strong> y animaciones hechas a mano con <strong>Maya</strong>.",
    github: "https://github.com/Toto-RR/CITM-FIGHTERS",
    image: "./projects/citmfigthers.webp",
    icon: GitHub,
  },
  {
    title: "FINITE STATES MACHINE",
    github: "https://github.com/Toto-RR/AI-FiniteStatesMachine",
    description:
      "Pequeño proyecto donde una <strong>IA</strong> se esconde de otra IA que le busca utilizando <strong>Máquinas de Estado</strong>, desarrollado en <strong>Unity</strong>.",
    image: "./projects/IA.webp",
    icon: GitHub,
  },
  {
    title: "'ABOUT US' SECTION",
    github: "https://clapcom-studios.github.io/Website/aboutus.html",
    description:
      "Apartado de la web para el proyecto de <strong>Alien: Extraction</strong>, donde se daba a conocer a los integrantes sus respectivos roles.",
    image: "./projects/AboutUs.webp",
    icon: Link,
  },
];

const firstParagraph = (html: string) => {
  // coge el primer <p ...>...</p>
  const match = html.match(/<p\b[^>]*>[\s\S]*?<\/p>/i);
  return match ? match[0] : html;
};
---

<div class="project-grid">
  {
    OTHER_PROJECTS.map(({ slug, image, title, description, github, link }) => (
      <div class="project-card dark:bg-gray-900">
        <a
          href={`/projects/${slug}`}
          class="card-overlay"
          aria-label={`Abrir proyecto ${title}`}
        />

        <img
          alt="Imagen del proyecto"
          class="project-image card-no-click"
          loading="lazy"
          src={image}
        />

        <div class="project-title">
          <h3 class="card-no-click">{title}</h3>

          <div class="card-actions">
            {github && (
              <LinkButton href={github}>
                <GitHub class="size-6" />
              </LinkButton>
            )}
            {link && (
              <LinkButton href={link}>
                <Link class="size-6" />
              </LinkButton>
            )}
          </div>
        </div>

        <div
          class="project-description card-no-click text-s text-gray-600 dark:text-gray-300 mb-2"
          set:html={firstParagraph(description)}
        />
      </div>
    ))
  }
</div>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    align-items: stretch;
    gap: 16px;
  }

  .project-image {
    height: 200px;
    object-fit: cover;
    width: 100%;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition:
      transform 0.3s,
      box-shadow 0.3s;
    justify-content: space-between;
    position: relative;
  }
  
  
  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    border-radius: 8px;
  }

  
  .card-no-click {
    pointer-events: none;
  }

  .card-actions {
    position: relative;
    z-index: 20;
    pointer-events: auto;
    display: flex;
    gap: 16px;
  }
  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 8px 12px rgba(0, 0, 0, 0.2);
    background-color: rgba(85, 137, 214, 0.2);
  }

  .project-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 15px;
    text-align: start;
    font-weight: bold;
    color: #333;
    width: 100%;
  }

  .icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f0f0f0;
    border-radius: 50%;
    padding: 4px;
    transition: background-color 0.3s;
  }

  .icon-link:hover {
    background-color: #e0e0e0;
  }

  .project-card .project-description {
    color: currentColor;
    padding-left: 15px;
    padding-right: 15px;
    padding-bottom: 15px;
  }

  :global(.project-title h3) {
    color: #006699;
    font-weight: 800;
    font-size: 120%;
  }

  :global(.dark .project-title h3) {
    color: #38bdf8;
    font-weight: 800;
    font-size: 120%;
  }

  :global(.dark .project-description strong) {
    color: #36b6ee;
  }

  :global(.project-description strong) {
    color: #006699;
  }
</style>
