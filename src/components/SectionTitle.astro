---
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
}

const { title, subtitle, eyebrow } = Astro.props;
---

<div class="section-heading">
  {eyebrow && (
    <div class="section-eyebrow">
      <span class="section-eyebrow-line"></span>
      <span>{eyebrow}</span>
    </div>
  )}
  <h2>{title}</h2>
  {subtitle && <p>{subtitle}</p>}
</div>

<style>
  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .section-eyebrow-line {
    width: 42px;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
    flex-shrink: 0;
  }
</style>