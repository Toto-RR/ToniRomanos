---
const personalImageAlt = "Toni Romanos";
import Badge from "@/components/Badge.astro";
import LinkedInIcon from "@/components/icons/LinkedIn.astro";
import MailIcon from "@/components/icons/Mail.astro";
import SocialPill from "@/components/SocialPill.astro";
import GitHub from "./icons/GitHub.astro";
import Descargar from "./icons/Descargar.astro"
---

<div class="max-w-4xl mt-6">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full shadow-lg size-16"
      src="./profile.webp"
      alt={personalImageAlt}
    />
    <a
      href="https://www.linkedin.com/in/toniromanos/"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>Disponible para trabajar</Badge>
    </a>
  </div>
  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    Hola! Soy Toni Romanos
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
  >
    <strong>Game Developer</strong> graduado en 
    <strong>Diseño y Desarrollo de Videojuegos</strong>
    de Barcelona, España 🇪🇸. <br>Enfocado en la <strong>programación</strong>. Especializado en <strong>C# y Unity</strong>.
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="/RomanosToni_CV.pdf">
      <Descargar class="size-4" />
      CV
    </SocialPill>
    <SocialPill href="https://www.linkedin.com/in/toniromanos">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href="https://github.com/Toto-RR">
      <GitHub class="size-4" />
      GitHub
    </SocialPill>
    
    <SocialPill href="mailto:toni.romanos.ruiz@gmail.com">
      <MailIcon class="size-4" />
      toni.romanos.ruiz@gmail.com
    </SocialPill>
  </nav>
</div>
