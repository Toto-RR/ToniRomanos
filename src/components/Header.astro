---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { title: "Proyectos", label: "proyectos", url: "/#proyectos" },
  {
    title: "Otros proyectos",
    label: "otros-proyectos",
    url: "/#otros-proyectos",
  },
  { title: "Habilidades", label: "habilidades", url: "/#habilidades" },
  { title: "Experiencia", label: "experiencia", url: "/#experiencia" },
  { title: "Estudios", label: "estudios", url: "/#estudios" },
  { title: "Sobre mí", label: "sobre-mi", url: "/#sobre-mi" },
];
---

<header
  class="fixed top-0 z-50 flex items-center justify-center w-full mx-auto mt-2 mb-2 px-1"
>
  <nav
    class="flex flex-wrap text-sm font-medium rounded-full text-gray-600 dark:text-gray-200 justify-center items-center px-2 py-1"
  >
    {
      navItems.map((link) => (
        <a
          class="nav-link relative block px-2 py-1 transition hover:text-blue-500 dark:hover:text-blue-500"
          aria-label={link.label}
          href={link.url}
          data-target={link.label}
        >
          {link.title}
        </a>
      ))
    }
    <ThemeToggle />
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const navLinks = Array.from(
      document.querySelectorAll("header nav a.nav-link"),
    ) as HTMLElement[];
    const sections = Array.from(document.querySelectorAll("section[id]"));

    const setActive = (id: string) => {
      navLinks.forEach((a) => {
        a.classList.toggle("text-blue-500", a.dataset.target === id);
      });
    };

    // 1) Scroll suave SIN navegación cuando ya estás en la home
    navLinks.forEach((a) => {
      a.addEventListener("click", (e) => {
        const targetId = a.dataset.target;
        if (!targetId) return;

        const isHome = location.pathname === "/" || location.pathname === "";
        if (!isHome) return; // si estás en otra página, deja que navegue a /#seccion

        const el = document.getElementById(targetId);
        if (!el) return;

        e.preventDefault();

        // actualiza el hash sin recargar
        history.pushState(null, "", `/#${targetId}`);

        // scroll suave a la sección (con margen por el header)
        el.scrollIntoView({ behavior: "smooth", block: "start" });

        // activa el link al instante
        setActive(targetId);
      });
    });

    // 2) Highlight estable con IntersectionObserver (elige el más visible)
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible) setActive(visible.target.id);
      },
      {
        root: null,
        rootMargin: "-30% 0px -55% 0px", // hace el "punto activo" en el centro aprox
        threshold: [0.1, 0.2, 0.35, 0.5, 0.65],
      },
    );

    sections.forEach((s) => observer.observe(s));

    // 3) Si entras con hash (o recargas), marca bien el activo
    const initial = location.hash?.slice(1);
    if (initial) setActive(initial);

    // Cleanup
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "hidden") observer.disconnect();
      else sections.forEach((s) => observer.observe(s));
    });
  });
</script>
<style>
  nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  nav {
    @apply dark:bg-gray-800/90 bg-white/50;
  }

  @keyframes nav-shadown {
    0% {
      @apply dark:bg-gray-800/0 bg-white/0;
    }
    to {
      @apply shadow-lg ring-1 backdrop-blur ring-white/10;
    }
  }
  section {
  scroll-margin-top: 90px; /* ajusta a la altura real de tu header */
}
</style>
