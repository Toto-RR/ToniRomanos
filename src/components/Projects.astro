---
import GitHub from "./icons/GitHub.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";

import { FEATURED_PROJECTS } from "@/data/projects";
---

<style is:global>
  .project-image {
    height: 410px;
    object-fit: cover;
    width: 100%;
    object-position: center;
  }

  :root {
    --accent-strong: #006699;
  }

  .dark {
    --accent-strong: #38bdf8;
  }

  strong {
    font-weight: 600;
    color: var(--accent-strong);
  }

  .project-card[data-playing="true"] .trailer,
  .project-card[data-playing="true"] .yt {
    opacity: 1;
  }

  .project-card[data-playing="true"] .cover {
    opacity: 0;
  }

  /* Botón de audio: visible cuando hay hover o cuando está reproduciendo */
  .project-card:hover .audio-toggle,
  .project-card[data-playing="true"] .audio-toggle {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div class="flex flex-col gap-y-16 mx-auto max-w-full">
  {
    FEATURED_PROJECTS.map(
      ({ slug, image, title, href, description, tags, link, github, trailer, youtubeVideoId }) => (
      <article
        class="project-card group relative flex flex-col md:flex-row gap-8 border border-gray-300 dark:border-gray-700 rounded-xl p-6 text-left transition hover:transform hover:scale-[1.02]"
        data-youtube={youtubeVideoId ?? ""}
      >
        <!-- Overlay link -->
        <a
          href={href ?? `/projects/${slug}`}
          class="absolute inset-0 z-0 rounded-xl"
          aria-label={`Abrir proyecto ${title}`}
        />

        <div class="relative z-10 pointer-events-none w-full flex flex-col md:flex-row gap-8">
          <div class="w-full md:w-1/2 self-center">
            <div class="border border-gray-300 dark:border-gray-700 rounded-xl overflow-hidden">
              <div class="relative aspect-video w-full overflow-hidden rounded-xl border border-gray-300 dark:border-gray-700">
                <img
                  src={image}
                  alt="Imagen no disponible"
                  class="cover absolute inset-0 h-full w-full object-cover transition-opacity duration-300 ease-out"
                  loading="lazy"
                />

                {/* Trailer local */}
                {trailer && (
                  <>
                    <video
                      class="trailer absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-300 ease-out"
                      muted
                      playsinline
                      preload="metadata"
                      poster={image}
                    >
                      <source src={trailer} type="video/mp4" />
                    </video>

                    <button
                      class="audio-toggle pointer-events-auto absolute bottom-3 right-3 z-30
                            bg-black/60 backdrop-blur-sm text-white text-sm
                            px-3 py-1.5 rounded-full
                            opacity-0 translate-y-1
                            transition-all duration-200 hover:bg-black/80"
                      type="button"
                      aria-label="Activar o desactivar sonido del tráiler"
                    >
                      🔇
                    </button>
                  </>
                )}

                {/* Placeholder YouTube (se inyecta iframe al hover) */}
                {!trailer && youtubeVideoId && (
                  <div class="yt absolute inset-0 opacity-0 transition-opacity duration-300 ease-out"></div>
                )}
              </div>
            </div>
          </div>

          <div class="w-full md:w-1/2 flex flex-col">
            <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
              {title}
            </h3>

            <ul class="flex flex-wrap gap-2 mb-2 mt-2">
              {tags.map((tag) => (
                <li>
                  <span class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2`}>
                    <tag.icon class="size-4" />
                    {tag.name}
                  </span>
                </li>
              ))}
            </ul>

            <div class="mt-2 text-gray-700 dark:text-gray-400 space-y-4 [&>p]:mb-4 [&>p]:last-child:mb-0">
              <Fragment set:html={description} />
            </div>

            <footer class="pointer-events-auto flex justify-end mt-auto pt-4 gap-x-4">
              {github && (
                <LinkButton href={github}>
                  <GitHub class="size-6" />
                  Code
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link class="size-4" />
                  Web
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    ),
  )
}
</div>

<script>
  function extractYouTubeId(raw:string): string {
    if (!raw) return "";
    // Si ya es ID (11 chars típicos), lo dejamos
    if (/^[a-zA-Z0-9_-]{11}$/.test(raw)) return raw;

    // Si es URL, intentamos extraer v= o youtu.be/
    try {
      const url = new URL(raw);
      const v = url.searchParams.get("v");
      if (v) return v;
      if (url.hostname.includes("youtu.be")) return url.pathname.replace("/", "");
    } catch {}
    return "";
  }

  function ensureYouTubeIframe(card: HTMLElement) {
    const holder = card.querySelector<HTMLElement>(".yt");
    if (!holder) return;

    // Evita recrear si ya existe
    if (holder.querySelector("iframe")) return;

    const raw = card.getAttribute("data-youtube") || "";
    const id = extractYouTubeId(raw);
    if (!id) return;

    const iframe = document.createElement("iframe");
    iframe.className = "absolute inset-0 w-full h-full rounded-xl";
    iframe.setAttribute("title", "YouTube trailer preview");
    iframe.setAttribute("frameborder", "0");
    iframe.setAttribute(
      "allow",
      "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    );
    iframe.setAttribute("allowfullscreen", "true");

    // Autoplay muted + loop (playlist=id) para que pueda loop
    const origin = encodeURIComponent(window.location.origin);

    iframe.src =
      `https://www.youtube-nocookie.com/embed/${id}` +
      `?autoplay=1&mute=1&controls=0&rel=0&playsinline=1&modestbranding=1` +
      `&loop=1&playlist=${id}&origin=${origin}`;
    holder.style.position = "absolute";
    holder.appendChild(iframe);
  }

  function destroyYouTubeIframe(card: HTMLElement) {
    const holder = card.querySelector(".yt");
    if (!holder) return;
    holder.innerHTML = "";
  }

  function play(card: HTMLElement) {
    const video = card.querySelector("video");

    // Trailer local
    if (video) {
      video.muted = true;
      video.currentTime = 0;
      video.play().catch(() => {});
      card.setAttribute("data-playing", "true");
      return;
    }

    // YouTube
    const yt = card.querySelector(".yt");
    const ytId = (card.getAttribute("data-youtube") || "").trim();
    if (yt && ytId) {
      ensureYouTubeIframe(card);
      card.setAttribute("data-playing", "true");
    }
  }

  function pause(card: HTMLElement) {
    const video = card.querySelector("video");
    if (video) {
      video.pause();
      video.currentTime = 0;
      card.setAttribute("data-playing", "false");
      return;
    }

    // YouTube: lo destruimos para parar reproducción
    const yt = card.querySelector(".yt");
    if (yt) {
      destroyYouTubeIframe(card);
      card.setAttribute("data-playing", "false");
    }
  }

  function initFeaturedCards() {
    const cards = document.querySelectorAll<HTMLElement>(".project-card");

    cards.forEach((card) => {
      // Evita duplicar listeners si Astro re-ejecuta init
      if (card.dataset.bound === "true") return;
      card.dataset.bound = "true";

      const video = card.querySelector("video");
      const button = card.querySelector(".audio-toggle");

      card.addEventListener("mouseenter", () => play(card));
      card.addEventListener("mouseleave", () => {
        pause(card);
        if (video) {
          video.muted = true;
          if (button) button.textContent = "🔇";
        }
      });

      // Accesible con teclado
      card.addEventListener("focusin", () => play(card));
      card.addEventListener("focusout", () => {
        pause(card);
        if (video) {
          video.muted = true;
          if (button) button.textContent = "🔇";
        }
      });

      // Audio toggle (solo si hay video local)
      if (video && button) {
        button.addEventListener("click", (e) => {
          e.stopPropagation();
          video.muted = !video.muted;
          button.textContent = video.muted ? "🔇" : "🔊";
        });
      }
    });
  }

  // Astro client-side navigation
  document.addEventListener("astro:page-load", initFeaturedCards);

  // Back/forward cache del navegador
  window.addEventListener("pageshow", initFeaturedCards);

  // Carga inicial
  initFeaturedCards();
</script>