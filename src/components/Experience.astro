---
import type { ExperienceItem } from "../data/experience";

const { items } = Astro.props as { items: ExperienceItem[] };
---

<section class="section" id="experience">
  <div class="section-heading">
    <h2>Experiencia</h2>
    <p>
      Desarrollo de videojuegos, prototipos y proyectos técnicos aplicados a contextos reales.
    </p>
  </div>

  <div class="experience-grid-alt">
    {items.map((item) => (
      <article class="experience-card-alt">
        <div class="experience-card-alt-top">
          <div>
            <p class="experience-company">{item.company}</p>
            <h3>{item.role}</h3>
          </div>

          <div class="experience-meta-alt">
            <span class="experience-period">{item.period}</span>
            <span class="experience-type">{item.type}</span>
          </div>
        </div>

        <p class="experience-description">{item.description}</p>

        <ul class="experience-highlights">
          {item.highlights.map((point) => <li>{point}</li>)}
        </ul>
      </article>
    ))}
  </div>
</section>